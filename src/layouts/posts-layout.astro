---
import PageHeading from "../components/page-heading.astro";
import PostsLoop from "../components/posts-loop.astro";
import Layout from "../layouts/main.astro";
import translations from "../locales/translations.ts";
const currentLocale = Astro.currentLocale || 'en';
---

<Layout title={translations[currentLocale].posts.title}>
  <section class="relative z-20 max-w-2xl mx-auto my-12 px-7 lg:px-0">
    <PageHeading
      title={translations[currentLocale].posts.title}
      description={translations[currentLocale].posts.description}
    />

    <div class="z-50 flex flex-col items-stretch w-full gap-5 my-8">
      <PostsLoop count="999999999" />
    </div>
  </section>
</Layout>